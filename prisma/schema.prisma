// This file is automatically generated by Keystone, do not modify it manually.
// Modify your Keystone config when you want to change this.

datasource sqlite {
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  provider          = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(cuid())
  name      String    @default("")
  email     String    @unique @default("")
  password  String
  createdAt DateTime? @default(now())

  projects Project[] // Relación inversa con Project
}

model Region {
  languageCode             String                @id
  name                     String                @default("")
  parentRegion             Region?               @relation("Region_parentRegion", fields: [parentRegionId], references: [languageCode])
  parentRegionId           String?               @map("parentRegion")
  timeZone                 String                @default("")
  defaultFormalityLevel    String?
  notes                    String                @default("")
  culturalData             CulturalData[]        @relation("CulturalData_region")
  conversationTactics      ConversationTactic[]  @relation("ConversationTactic_region")
  from_Region_parentRegion Region[]              @relation("Region_parentRegion")
  from_RagDocumentMetadata RagDocumentMetadata[] @relation("RagDocumentMetadata_region")

  @@index([parentRegionId])
}

model CulturalData {
  id                  String               @id
  regionId            String
  region              Region               @relation("CulturalData_region", fields: [regionId], references: [languageCode])
  formalityLevel      Int?
  style               String               @default("")
  considerations      String               @default("")
  notes               String               @default("")
  conversationTactics ConversationTactic[] @relation("ConversationTactic_culturalData")

  @@index([regionId])
}

model ConversationTactic {
  name           String               @id
  region         Region?              @relation("ConversationTactic_region", fields: [regionId], references: [languageCode])
  regionId       String?              @map("region")
  culturalData   CulturalData?        @relation("ConversationTactic_culturalData", fields: [culturalDataId], references: [id])
  culturalDataId String?
  tacticsConfig  String?
  prompts        ConversationPrompt[] @relation("ConversationPrompt_tactic")

  @@index([regionId])
  @@index([culturalDataId])
}

model ConversationPrompt {
  name            String                      @id
  description     String                      @default("")
  tactic          ConversationTactic?         @relation("ConversationPrompt_tactic", fields: [tacticId], references: [name])
  tacticId        String?                     @map("tactic")
  versions        ConversationPromptVersion[] @relation("ConversationPromptVersion_prompt")
  activeVersion   ConversationPromptVersion?  @relation("ConversationPrompt_activeVersion", fields: [activeVersionId], references: [id])
  activeVersionId String?                     @unique
  tags            Tag[]                       @relation("PromptTags")

  @@index([tacticId])
}

model ConversationPromptVersion {
  id              String                        @id @default(cuid())
  prompt          ConversationPrompt            @relation("ConversationPromptVersion_prompt", fields: [promptId], references: [name])
  promptId        String                        @map("prompt")
  promptText      String                        @default("")
  versionTag      String                        @default("v1.0.0")
  changeMessage   String?
  createdAt       DateTime                      @default(now())
  translations    PromptTranslation[]           @relation("PromptTranslation_version")
  assets          ConversationPromptAssetLink[] @relation("ConversationPromptAssetLink_promptVersion")
  activeForPrompt ConversationPrompt?           @relation("ConversationPrompt_activeVersion")

  @@unique([promptId, versionTag])
  @@index([promptId])
}

model PromptTranslation {
  id           String                    @id @default(cuid())
  version      ConversationPromptVersion @relation("PromptTranslation_version", fields: [versionId], references: [id])
  versionId    String                    @map("version")
  languageCode String
  promptText   String                    @default("")

  @@unique([versionId, languageCode])
  @@index([versionId])
  @@index([languageCode])
}

model ConversationPromptAsset {
  key             String                           @id
  name            String                           @default("")
  type            String?
  description     String                           @default("")
  category        String?
  versions        ConversationPromptAssetVersion[] @relation("ConversationPromptAssetVersion_asset")
  activeVersion   ConversationPromptAssetVersion?  @relation("ConversationPromptAsset_activeVersion", fields: [activeVersionId], references: [id])
  activeVersionId String?                          @unique
}

model ConversationPromptAssetVersion {
  id             String                        @id @default(cuid())
  asset          ConversationPromptAsset       @relation("ConversationPromptAssetVersion_asset", fields: [assetId], references: [key])
  assetId        String                        @map("asset")
  value          String                        @default("")
  versionTag     String                        @default("v1.0.0")
  changeMessage  String?
  createdAt      DateTime                      @default(now())
  translations   AssetTranslation[]            @relation("AssetTranslation_version")
  links          ConversationPromptAssetLink[] @relation("ConversationPromptAssetLink_assetVersion")
  activeForAsset ConversationPromptAsset?      @relation("ConversationPromptAsset_activeVersion")

  @@unique([assetId, versionTag])
  @@index([assetId])
}

model AssetTranslation {
  id           String                         @id @default(cuid())
  version      ConversationPromptAssetVersion @relation("AssetTranslation_version", fields: [versionId], references: [id])
  versionId    String                         @map("version")
  languageCode String
  value        String                         @default("")

  @@unique([versionId, languageCode])
  @@index([versionId])
  @@index([languageCode])
}

model ConversationPromptAssetLink {
  id              String                         @id @default(cuid())
  promptVersion   ConversationPromptVersion      @relation("ConversationPromptAssetLink_promptVersion", fields: [promptVersionId], references: [id])
  promptVersionId String                         @map("promptVersion")
  assetVersion    ConversationPromptAssetVersion @relation("ConversationPromptAssetLink_assetVersion", fields: [assetVersionId], references: [id])
  assetVersionId  String                         @map("assetVersion")
  usageContext    String                         @default("")
  position        Int?

  @@index([promptVersionId])
  @@index([assetVersionId])
}

model RagDocumentMetadata {
  id                 String  @id @default(cuid())
  region             Region? @relation("RagDocumentMetadata_region", fields: [regionId], references: [languageCode])
  regionId           String? @map("region")
  documentName       String  @default("")
  category           String?
  complianceReviewed Boolean @default(false)
  piiRiskLevel       String?
  lastReviewedBy     String  @default("")

  @@index([regionId])
}

model Tag {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  prompts     ConversationPrompt[] @relation("PromptTags")
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  ownerUserId String?   @map("ownerUser") // Mapea al campo de la FK en la BD
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner       User?     @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  // prompts     ConversationPrompt[] // Relación potencial a añadir después
  // assets      ConversationPromptAsset[] // Relación potencial a añadir después

  @@index([ownerUserId])
}

model AIModel {
  id            String    @id @default(cuid())
  name          String    @unique // Ej: GPT-4 Turbo, Claude 3 Sonnet
  provider      String?   // Ej: OpenAI, Anthropic, Google
  description   String?
  apiIdentifier String?   // Identificador para llamadas API
  createdAt     DateTime  @default(now())

  // promptVersions ConversationPromptVersion[] // Relación potencial a añadir después
  // assetVersions  ConversationPromptAssetVersion[] // Relación potencial a añadir después
}
