model SystemPrompt {
  id           String    @id @default(cuid())
  name         String    @unique // Nombre único para identificarlo (e.g., 'summarize_text', 'translate_es_en')
  description  String?   // Descripción opcional
  promptText   String    // El texto base del prompt del sistema
  category     String?   // Categoría opcional para agruparlos (e.g., 'summarization', 'translation')
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Nota: Sin relación directa con Project, User, etc.
}
