// This file is automatically generated by Keystone, do not modify it manually.
// Modify your Keystone config when you want to change this.

datasource sqlite {
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  provider          = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(cuid())
  name      String    @default("")
  email     String    @unique @default("")
  password  String
  createdAt DateTime? @default(now())

  projects            Project[]
  promptExecutionLogs PromptExecutionLog[] // Relación inversa añadida
}

model Region {
  languageCode             String                @id
  name                     String                @default("")
  parentRegion             Region?               @relation("Region_parentRegion", fields: [parentRegionId], references: [languageCode])
  parentRegionId           String?               @map("parentRegion")
  timeZone                 String                @default("")
  defaultFormalityLevel    String?
  notes                    String                @default("")
  culturalData             CulturalData[]        @relation("CulturalData_region")
  from_Region_parentRegion Region[]              @relation("Region_parentRegion")
  from_RagDocumentMetadata RagDocumentMetadata[] @relation("RagDocumentMetadata_region")

  project                  Project               @relation("ProjectRegions", fields: [projectId], references: [id], onDelete: Cascade)
  projectId                String                @map("project")

  @@index([parentRegionId])
  @@index([projectId])
}

model CulturalData {
  id                  String               @id
  regionId            String
  region              Region               @relation("CulturalData_region", fields: [regionId], references: [languageCode])
  formalityLevel      Int?
  style               String               @default("")
  considerations      String               @default("")
  notes               String               @default("")

  project             Project              @relation("ProjectCulturalData", fields: [projectId], references: [id], onDelete: Cascade)
  projectId           String               @map("project")

  // --- Añadir relación inversa opcional a Tactic (si aplica) ---
  tactic              Tactic?              @relation("TacticCulturalData", fields: [tacticId], references: [id], onDelete: SetNull)
  tacticId            String?              @map("tactic") @unique // @unique asegura relación 1-a-1

  @@index([regionId])
  @@index([projectId])
  @@index([tacticId]) // Si se añade tacticId
}

model Prompt {
  id              String            @id @default(cuid())
  name            String
  description     String            @default("")
  versions        PromptVersion[]   @relation("PromptVersion_prompt")
  tags            Tag[]             @relation("PromptTags")
  project         Project           @relation("ProjectPrompts", fields: [projectId], references: [id], onDelete: Cascade)
  projectId       String            @map("project")

  // --- Añadir relación a Tactic ---
  tactic          Tactic?           @relation(fields: [tacticId], references: [id], onDelete: SetNull)
  tacticId        String?           // Clave foránea opcional para Tactic

  @@index([projectId])
  @@unique([projectId, name])
  @@index([tacticId]) // Añadir índice para la nueva clave foránea
}

model PromptVersion {
  id                  String             @id @default(cuid())
  prompt              Prompt             @relation("PromptVersion_prompt", fields: [promptId], references: [id])
  promptId            String             @map("prompt")
  promptText          String             @default("")
  versionTag          String             @default("v1.0.0")
  changeMessage       String?
  status              String             @default("draft")
  createdAt           DateTime           @default(now())
  translations        PromptTranslation[] @relation("PromptTranslation_version")
  assets              PromptAssetLink[]  @relation("PromptAssetLink_promptVersion")
  activeInEnvironments Environment[]      @relation("ActivePromptsInEnvironment")
  executionLogs       PromptExecutionLog[] // Relación inversa añadida
  aiModel             AIModel?           @relation(fields: [aiModelId], references: [id]) // Optional link to a global AI Model
  aiModelId           String?            // FK for AIModel

  // Implicitly linked to Project via Prompt
  @@unique([promptId, versionTag])
  @@index([promptId])
  @@index([aiModelId]) // Index the new FK
}

model PromptTranslation {
  id           String        @id @default(cuid())
  version      PromptVersion @relation("PromptTranslation_version", fields: [versionId], references: [id])
  versionId    String        @map("version")
  languageCode String
  promptText   String        @default("")

  @@unique([versionId, languageCode])
  @@index([versionId])
  @@index([languageCode])
}

model PromptAsset {
  key             String                @id
  name            String                @default("")
  type            String?
  description     String                @default("")
  category        String?
  enabled         Boolean               @default(true)
  versions        PromptAssetVersion[]  @relation("PromptAssetVersion_asset")
  project         Project               @relation("ProjectAssets", fields: [projectId], references: [id], onDelete: Cascade)
  projectId       String                @map("project")

  @@index([projectId])
}

model PromptAssetVersion {
  id                  String             @id @default(cuid())
  asset               PromptAsset        @relation("PromptAssetVersion_asset", fields: [assetId], references: [key])
  assetId             String             @map("asset")
  value               String             @default("")
  versionTag          String             @default("v1.0.0")
  changeMessage       String?
  status              String             @default("draft")
  createdAt           DateTime           @default(now())
  translations        AssetTranslation[] @relation("AssetTranslation_version")
  links               PromptAssetLink[]  @relation("PromptAssetLink_assetVersion")
  activeInEnvironments Environment[]      @relation("ActiveAssetsInEnvironment")

  // Implicitly linked to Project via PromptAsset
  @@unique([assetId, versionTag])
  @@index([assetId])
}

model AssetTranslation {
  id           String             @id @default(cuid())
  version      PromptAssetVersion @relation("AssetTranslation_version", fields: [versionId], references: [id])
  versionId    String             @map("version")
  languageCode String
  value        String             @default("")

  @@unique([versionId, languageCode])
  @@index([versionId])
  @@index([languageCode])
}

model PromptAssetLink {
  id              String             @id @default(cuid())
  promptVersion   PromptVersion      @relation("PromptAssetLink_promptVersion", fields: [promptVersionId], references: [id])
  promptVersionId String             @map("promptVersion")
  assetVersion    PromptAssetVersion @relation("PromptAssetLink_assetVersion", fields: [assetVersionId], references: [id])
  assetVersionId  String             @map("assetVersion")
  usageContext    String             @default("")
  position        Int?
  insertionLogic  String?
  isRequired      Boolean            @default(true)

  @@unique([promptVersionId, assetVersionId])
  @@index([promptVersionId])
  @@index([assetVersionId])
}

model RagDocumentMetadata {
  id                 String  @id @default(cuid())
  region             Region? @relation("RagDocumentMetadata_region", fields: [regionId], references: [languageCode])
  regionId           String? @map("region")
  documentName       String  @default("")
  category           String?
  complianceReviewed Boolean @default(false)
  piiRiskLevel       String?
  lastReviewedBy     String  @default("")

  project            Project @relation("ProjectRagDocs", fields: [projectId], references: [id], onDelete: Cascade)
  projectId          String  @map("project")

  @@index([regionId])
  @@index([projectId])
}

model Tag {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  prompts     Prompt[] @relation("PromptTags")

  project     Project  @relation("ProjectTags", fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String   @map("project")

  // --- Añadir relación inversa ---
  // tactics             Tactic[]             @relation("ProjectTactics") // Añadir relación inversa // ESTO ESTABA MAL AQUÍ

  @@unique([projectId, name])
  @@index([projectId])
}

model Project {
  id                  String               @id @default(cuid())
  name                String
  description         String?
  ownerUserId         String?              @map("ownerUser")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  owner               User?                @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  prompts             Prompt[]             @relation("ProjectPrompts")
  assets              PromptAsset[]        @relation("ProjectAssets")
  regions             Region[]             @relation("ProjectRegions")
  culturalData        CulturalData[]       @relation("ProjectCulturalData")
  ragDocs             RagDocumentMetadata[] @relation("ProjectRagDocs")
  tags                Tag[]                @relation("ProjectTags")
  environments        Environment[]        @relation("ProjectEnvironments")
  promptExecutionLogs PromptExecutionLog[] @relation("ProjectLogs")
  aiModels            AIModel[]            @relation("ProjectModels")

  // --- Añadir relación inversa ---
  tactics             Tactic[]             @relation("ProjectTactics") // Añadir relación inversa

  @@index([ownerUserId])
}

model AIModel {
  id            String    @id @default(cuid())
  name          String    // Removed global @unique
  provider      String?   // Ej: OpenAI, Anthropic, Google
  description   String?
  apiIdentifier String?   // Identificador para llamadas API (e.g., "gpt-4o-2024-05-13")
  apiKeyEnvVar  String?   // Nombre de la variable de entorno para la API Key (e.g., "OPENAI_API_KEY") - Made optional
  temperature   Float?    // Added temperature field
  createdAt     DateTime  @default(now())
  maxTokens     Int?
  supportsJson  Boolean @default(false)
  contextWindow Int?   // Tamaño máximo de contexto

  // Re-add relation to Project
  project       Project   @relation("ProjectModels", fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String    // Re-add projectId field

  // Keep back-relation to PromptVersion
  promptVersions PromptVersion[]

  // Re-add project-specific constraints
  @@unique([projectId, name]) // Name must be unique within a project
  @@index([projectId])
}

model Environment {
  id                  String             @id @default(cuid())
  name                String             @unique
  description         String?
  activePromptVersions PromptVersion[]    @relation("ActivePromptsInEnvironment")
  activeAssetVersions PromptAssetVersion[] @relation("ActiveAssetsInEnvironment")
  promptExecutionLogs PromptExecutionLog[] // Relación inversa añadida

  project             Project            @relation("ProjectEnvironments", fields: [projectId], references: [id], onDelete: Cascade)
  projectId           String             @map("project")

  @@unique([projectId, name])
  @@index([projectId])
}

// --- LOGGING --- //

model PromptExecutionLog {
  id            String        @id @default(cuid())
  timestamp     DateTime      @default(now())

  // --- Contexto del Prompt ---
  promptVersion PromptVersion @relation(fields: [promptVersionId], references: [id])
  promptVersionId String      // FK explícita para PromptVersion

  // --- Contexto de Ejecución ---
  environment   Environment?  @relation(fields: [environmentId], references: [id]) // Entorno de ejecución
  environmentId String?
  user          User?         @relation(fields: [userId], references: [id])       // Usuario que ejecutó (si aplica)
  userId        String?
  // Podríamos añadir sessionId, requestId, etc. si son relevantes

  // --- Datos de Entrada/Salida ---
  input         String        // Input completo proporcionado (Considerar tipo Json si es complejo)
  output        String        // Output completo generado (Considerar tipo Json si es complejo)

  // --- Resultado y Métricas ---
  success       Boolean       // ¿Fue exitosa la ejecución?
  durationMs    Int?          // Duración de la ejecución en milisegundos
  errorMessage  String?       // Mensaje de error si success = false
  // Podríamos añadir métricas como tokenCount, cost, etc.

  project       Project        @relation("ProjectLogs", fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String         @map("project")

  @@index([promptVersionId])
  @@index([environmentId])
  @@index([userId])
  @@index([timestamp]) // Indexar timestamp para búsquedas por fecha
}

