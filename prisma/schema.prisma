model SystemPrompt {
  id           String    @id @default(cuid())
  name         String    @unique // Nombre único para identificarlo (e.g., 'summarize_text', 'translate_es_en')
  description  String?   // Descripción opcional
  promptText   String    // El texto base del prompt del sistema
  category     String?   // Categoría opcional para agruparlos (e.g., 'summarization', 'translation')
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Nota: Sin relación directa con Project, User, Tactic, etc.
}

// --- Añadir nuevo modelo Tactic ---
model Tactic {
  id            String        @id @default(cuid())
  name          String        // Asumiendo que 'name' es el identificador único usado en connect: { name: ... }
  description   String?
  culturalData  CulturalData? @relation("TacticCulturalData") // Asumiendo una relación uno a uno o uno a muchos opcional con CulturalData basado en el código
  // Si la relación con CulturalData es muchos a muchos o diferente, ajustar aquí.
  // Por ejemplo, si CulturalData debe tener una referencia a Tactic:
  // culturalData CulturalData[] @relation("TacticCulturalData") // En Tactic
  // tactic Tactic? @relation("TacticCulturalData", fields: [tacticId], references: [id]) // En CulturalData
  // tacticId String? // En CulturalData

  // Relación con Project (asumiendo que una Tactic pertenece a un Proyecto)
  project       Project       @relation("ProjectTactics", fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String        @map("project")

  // Relación inversa con Prompt
  prompts       Prompt[]

  @@unique([projectId, name]) // Nombre único dentro del proyecto
  @@index([projectId])
  // Añadir índice para la relación con CulturalData si es necesario, ej: @@index([culturalDataId])
}
