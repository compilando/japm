# VS Code REST Client Test Suite for japm.app API

# Variables (ajusta la base URL si es necesario)
@baseUrl = http://localhost:3000
# Variables con formato slug
@assetKeySaludo = saludo-test-{{$timestamp}}
@assetKeyDespedida = despedida-test-{{$timestamp}}
@promptNameBienvenida = bienvenida-test-{{$timestamp}}

# Placeholder con key slug
@placeholderSaludo = {{assetKeySaludo}}
@placeholderDespedida = {{assetKeyDespedida}}

###
# -------------------------
# ASSET MANAGEMENT (keys ya son slugs)
# -------------------------

### 1. Crear Asset "Saludo" (key en formato slug)
# @name createAssetSaludo
POST {{baseUrl}}/prompt-assets
Content-Type: application/json

{
  "key": "{{assetKeySaludo}}", # Key ya es slug
  "name": "Saludo Test",
  "description": "Asset para saludo de prueba",
  "type": "Greeting",
  "value": "Hello (base)",
  "initialTranslations": [
    {
      "languageCode": "es-ES",
      "value": "Hola (v1)"
    }
  ]
}

# @assetSaludoId = {{createAssetSaludo.response.body.$.id}} # ID CUID de la entidad Asset (ya no se usa para buscar)
@assetSaludoV1Id = {{createAssetSaludo.response.body.activeVersion.id}}

### 2. Crear Nueva Versión (v1.1.0) para Asset "Saludo"
# @name createAssetSaludoV1_1
POST {{baseUrl}}/prompt-assets/{{assetKeySaludo}}/versions # Usar key slug en URL
Content-Type: application/json

{
    "value": "Hello there (v1.1)",
    "versionTag": "v1.1.0",
    "changeMessage": "Added 'there'"
}

@assetSaludoV1_1Id = {{createAssetSaludoV1_1.response.body.$.id}}

### 3. Añadir/Actualizar Traducción ES para Asset "Saludo" v1.1.0
# @name updateAssetSaludoV1_1TransES
PUT {{baseUrl}}/prompt-assets/{{assetKeySaludo}}/versions/{{assetSaludoV1_1Id}}/translations # Usar key slug en URL
Content-Type: application/json

{
    "languageCode": "es-ES",
    "value": "Hola a todos (v1.1)"
}

### 4. Añadir Traducción FR para Asset "Saludo" v1.1.0
# @name addAssetSaludoV1_1TransFR
PUT {{baseUrl}}/prompt-assets/{{assetKeySaludo}}/versions/{{assetSaludoV1_1Id}}/translations # Usar key slug en URL
Content-Type: application/json

{
    "languageCode": "fr-FR",
    "value": "Bonjour (v1.1)"
}

### 5. Listar todos los Assets
# @name listAssets1
GET {{baseUrl}}/prompt-assets

### 6. Obtener detalles del Asset "Saludo"
# @name getAssetSaludoDetails
GET {{baseUrl}}/prompt-assets/{{assetKeySaludo}} # Usar key slug en URL

### 7. Crear Asset "Despedida" (key en formato slug)
# @name createAssetDespedida
POST {{baseUrl}}/prompt-assets
Content-Type: application/json

{
  "key": "{{assetKeyDespedida}}", # Key ya es slug
  "name": "Despedida Test",
  "initialValue": "Goodbye (base v1)"
}

# @assetDespedidaId = {{createAssetDespedida.response.body.$.id}}
@assetDespedidaV1Id = {{createAssetDespedida.response.body.activeVersion.id}}

###
# -------------------------
# PROMPT MANAGEMENT (name en formato slug)
# -------------------------

### 8. Crear Prompt "Bienvenida" (name en formato slug y tags en slug)
# @name createPromptBienvenida
POST {{baseUrl}}/prompts
Content-Type: application/json

{
  "name": "{{promptNameBienvenida}}", # Name ya es slug
  "description": "Prompt de bienvenida de prueba con tags",
  "promptText": "{{{{placeholderSaludo}}}}, welcome!",
  "tags": ["bienvenida", "test", "inicial"], # Tags ya son slugs
  "initialTranslations": [
    {
      "languageCode": "es-ES",
      "promptText": "{{{{placeholderSaludo}}}}, ¡bienvenido!"
    }
  ]
}

@promptBienvenidaV1Id = {{createPromptBienvenida.response.body.activeVersion.id}}


### 9. Crear Nueva Versión (v1.1.0) para Prompt "Bienvenida"
# @name createPromptBienvenidaV1_1
POST {{baseUrl}}/prompts/{{promptNameBienvenida}}/versions # Usar name slug en URL
Content-Type: application/json

{
    "promptText": "{{{{placeholderSaludo}}}} Welcome again. {{{{placeholderDespedida}}}}",
    "versionTag": "v1.1.0",
    "changeMessage": "Updated greeting asset, added farewell asset.",
    "assetLinks": [
        {
            "assetVersionId": "{{assetSaludoV1_1Id}}",
            "position": 1
        },
        {
            "assetVersionId": "{{assetDespedidaV1Id}}",
            "position": 2
        }
    ],
    "initialTranslations": [
        {
            "languageCode": "es-ES",
            "promptText": "{{{{placeholderSaludo}}}} Bienvenido de nuevo. {{{{placeholderDespedida}}}}"
        }
    ]
}

@promptBienvenidaV1_1Id = {{createPromptBienvenidaV1_1.response.body.$.id}}

### 10. Añadir Traducción FR para Prompt "Bienvenida" v1.1.0
# @name addPromptBienvenidaV1_1TransFR
PUT {{baseUrl}}/prompts/{{promptNameBienvenida}}/versions/{{promptBienvenidaV1_1Id}}/translations # Usar name slug en URL
Content-Type: application/json

{
    "languageCode": "fr-FR",
    "promptText": "{{{{placeholderSaludo}}}} Bienvenue encore. {{{{placeholderDespedida}}}}"
}

### 11. Listar Prompts
# @name listPrompts1
GET {{baseUrl}}/prompts

### 12. Obtener Detalles Prompt Bienvenida
# @name getPromptBienvenidaDetails1
GET {{baseUrl}}/prompts/{{promptNameBienvenida}} # Usar name slug en URL

### 12b. Actualizar Prompt Bienvenida (tags en formato slug)
# @name updatePromptBienvenidaTags
PUT {{baseUrl}}/prompts/{{promptNameBienvenida}} # Usar name slug en URL
Content-Type: application/json

{
    "description": "Descripción actualizada y nuevos tags",
    "tags": ["bienvenida", "actualizado"] # Tags ya son slugs
}

### 12c. Obtener Detalles Prompt Bienvenida (Verificar tags actualizados)
# @name getPromptBienvenidaDetailsUpdatedTags
GET {{baseUrl}}/prompts/{{promptNameBienvenida}} # Usar name slug en URL

### 12d. Actualizar Prompt Bienvenida (Eliminar todos los tags)
# @name updatePromptBienvenidaRemoveTags
PUT {{baseUrl}}/prompts/{{promptNameBienvenida}} # Usar name slug en URL
Content-Type: application/json

{
    "tags": []
}

### 12e. Obtener Detalles Prompt Bienvenida (Verificar tags eliminados)
# @name getPromptBienvenidaDetailsNoTags
GET {{baseUrl}}/prompts/{{promptNameBienvenida}} # Usar name slug en URL

### 13. Activar Versión v1.1.0 del Prompt Bienvenida
# @name activatePromptBienvenidaV1_1
PATCH {{baseUrl}}/prompts/{{promptNameBienvenida}}/versions/{{promptBienvenidaV1_1Id}}/activate # Usar name slug en URL

### 14. Obtener Detalles Prompt Bienvenida (v1.1.0 activa)
# @name getPromptBienvenidaDetails2
GET {{baseUrl}}/prompts/{{promptNameBienvenida}} # Usar name slug en URL

### 15. Desactivar Versión Activa del Prompt Bienvenida
# @name deactivatePromptBienvenida
PATCH {{baseUrl}}/prompts/{{promptNameBienvenida}}/deactivate # Usar name slug en URL

### 16. Obtener Detalles Prompt Bienvenida (Sin versión activa)
# @name getPromptBienvenidaDetails3
GET {{baseUrl}}/prompts/{{promptNameBienvenida}} # Usar name slug en URL

###
# -------------------------
# SERVE PROMPT (usando slugs)
# -------------------------

### 17. Servir Prompt Bienvenida v1.0.0
# PATCH {{baseUrl}}/prompts/{{promptNameBienvenida}}/versions/{{promptBienvenidaV1Id}}/activate

# 17a. Servir v1.0.0 en ES
# @name servePromptV1_ES
GET {{baseUrl}}/serve-prompt?promptId={{promptNameBienvenida}}&languageCode=es-ES # Usar name slug

# 17b. Servir v1.0.0 en EN (Base)
# @name servePromptV1_EN
GET {{baseUrl}}/serve-prompt?promptId={{promptNameBienvenida}} # Usar name slug

### 18. Servir Prompt Bienvenida v1.1.0 (Actívala primero)
# @name activatePromptBienvenidaV1_1_again
PATCH {{baseUrl}}/prompts/{{promptNameBienvenida}}/versions/{{promptBienvenidaV1_1Id}}/activate # Usar name slug

# 18a. Servir v1.1.0 en ES
# @name servePromptV1_1_ES
GET {{baseUrl}}/serve-prompt?promptId={{promptNameBienvenida}}&languageCode=es-ES # Usar name slug

# 18b. Servir v1.1.0 en FR
# @name servePromptV1_1_FR
GET {{baseUrl}}/serve-prompt?promptId={{promptNameBienvenida}}&languageCode=fr-FR # Usar name slug

# 18c. Servir v1.1.0 en EN (Base)
# @name servePromptV1_1_EN
GET {{baseUrl}}/serve-prompt?promptId={{promptNameBienvenida}} # Usar name slug

# 18d. Servir versión específica v1.0.0
# @name servePromptSpecificV1_EN
GET {{baseUrl}}/serve-prompt?promptId={{promptNameBienvenida}}&versionTag=v1.0.0&useLatestActive=false # Usar name slug

###
# -------------------------
# CLEANUP (usando slugs)
# -------------------------

### 19. Eliminar Prompt Bienvenida
# @name deletePromptBienvenida
DELETE {{baseUrl}}/prompts/{{promptNameBienvenida}} # Usar name slug

### 20. Eliminar Asset Saludo
# @name deleteAssetSaludo
DELETE {{baseUrl}}/prompt-assets/{{assetKeySaludo}} # Usar key slug

### 21. Eliminar Asset Despedida
# @name deleteAssetDespedida
DELETE {{baseUrl}}/prompt-assets/{{assetKeyDespedida}} # Usar key slug

# ... (Podrías añadir DELETE para la Táctica y los Tags si tienes endpoints para ellos) 